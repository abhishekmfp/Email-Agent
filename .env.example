# Email-Agent — environment variable template
# Copy to `.env` and fill in. NEVER commit a real .env (it is gitignored).
# All secrets below are placeholders; real values must come from your own
# Anthropic account and a Google Cloud "Desktop" OAuth client.

# ---------------------------------------------------------------------------
# Application (prefix-free)
# ---------------------------------------------------------------------------
# Human-readable product name. NOTE: this is NOT the approver name (see APP_USER_NAME).
APP_NAME=Email-Agent
# Log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO
# Environment: development | staging | production | test
ENVIRONMENT=development

# ---------------------------------------------------------------------------
# Anthropic LLM provider (prefix: ANTHROPIC_)
# ---------------------------------------------------------------------------
# Your Anthropic API key. Loaded from env only; never logged, prompted, or derived.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxx
# Model id used for draft generation.
ANTHROPIC_MODEL=claude-3-5-haiku-latest
# Hard timeout (seconds) for a single Anthropic request. Enforces outbound_timeout.
ANTHROPIC_REQUEST_TIMEOUT_SECONDS=30

# ---------------------------------------------------------------------------
# Gmail OAuth (prefix: GMAIL_)
# From a Google Cloud OAuth "Desktop app" client (PKCE public client — NO secret).
# ---------------------------------------------------------------------------
GMAIL_CLIENT_ID=your-google-oauth-client-id.apps.googleusercontent.com
# Authenticated account send address (MIME From header). Never derived from the draft.
GMAIL_FROM_ADDRESS=you@example.com
# The following have safe defaults; override only if your setup differs.
# GMAIL_AUTH_URI=https://accounts.google.com/o/oauth2/v2/auth
# GMAIL_TOKEN_URI=https://oauth2.googleapis.com/token
# GMAIL_REDIRECT_URI=http://localhost:8080/
# GMAIL_SCOPES=https://www.googleapis.com/auth/gmail.send
# GMAIL_REQUEST_TIMEOUT_SECONDS=30
# GMAIL_SEND_TIMEOUT_SECONDS=30

# ---------------------------------------------------------------------------
# Local human identity / approver (prefix: APP_USER_)
# Fallback approver name used when a send request does not supply one.
# Distinct from APP_NAME (product name) — see M8 fix.
# ---------------------------------------------------------------------------
APP_USER_NAME=Your Name
